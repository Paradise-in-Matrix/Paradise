{
  "name": "Paradise",
  "version": "0.17.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Paradise-in-Matrix/Paradise"
  },
  "scripts": {
    "notangle": "concurrently \"npx shadow-cljs watch app\" \"npx vite\"",
    "dev": "concurrently \"npx shadow-cljs watch app\" \"npx nbb src/utils/tangler.cljs\" \"npx vite\"",
    "me": "concurrently \"npx shadow-cljs watch app\" \"npx nbb src/utils/tangler.cljs\" \"npx vite\"",
    "release": "npx shadow-cljs release app && npx vite build",
    "serve": "npx serve -s dist -l 8000",
    "ubrn:web:build:release": "PATH=$HOME/.cargo/bin:/bin:$PATH && ubrn build web --config ubrn.config.yaml --release",
    "ubrn:web:build": "PATH=$HOME/.cargo/bin:/bin:$PATH && ubrn build web --config ubrn.config.yaml",
    "ubrn:checkout": "PATH=$HOME/.cargo/bin:/bin:$PATH && ubrn checkout --config ubrn.config.yaml",
    "ubrn:clean": "rm -Rf cpp/ src/generated/ src/index.web.ts*",
    "cap:generate": "npx capacitor-assets generate",
    "ios:sync": "npx cap sync ios",
    "ad:sync": "npx cap sync android"
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/status-bar": "^8.0.2",
    "@element-hq/element-call-embedded": "^0.16.3",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-mention": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "capacitor-set-version": "^2.2.0",
    "emojibase-data": "^17.0.0",
    "ffi-bindings": "^1.0.1",
    "matrix-widget-api": "^1.17.0",
    "nbb": "^1.4.206",
    "react": "^19",
    "react-dom": "^19",
    "react-virtuoso": "^4.18.1",
    "shadow-cljs": "^3.3.6",
    "typescript": "^5.9.3",
    "unicode-emoji-json": "^0.8.0",
    "uniffi-bindgen-react-native": "git+https://github.com/jhugman/uniffi-bindgen-react-native#5c01f3f7025d069aac1dd1fd51ca72bb76fdb243",
    "virtua": "^0.48.8",
    "workbox-precaching": "^7.4.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-computed-properties": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@capacitor/assets": "^3.0.5",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "concurrently": "^9.2.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}